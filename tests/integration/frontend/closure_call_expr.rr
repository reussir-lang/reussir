// RUN: %reussir-elab --mode semi %s | %FileCheck %s

// --- Test 1: chained call (make_adder(5)(37)) ---
fn make_adder(n : i32) -> i32 -> i32 {
    |x : i32| x + n
}

// CHECK-DAG: fn test_chained(v0 (n): i32) -> i32 {
// CHECK-NEXT-DAG:     closure_call(make_adder(v0) : (i32) -> i32, 37.0 : i32) : i32
// CHECK-NEXT-DAG: }
fn test_chained(n : i32) -> i32 {
    make_adder(n)(37)
}

// --- Test 2: immediate lambda call ---
// CHECK-DAG: fn test_immediate(v0 (x): i32) -> i32 {
// CHECK-NEXT-DAG:     closure_call(closure[](v1 : i32) {
// CHECK-NEXT-DAG:         (v1 + 1.0 : i32) : i32
// CHECK-NEXT-DAG:     } : (i32) -> i32, v0) : i32
// CHECK-NEXT-DAG: }
fn test_immediate(x : i32) -> i32 {
    (|y: i32| y + 1)(x)
}

// --- Test 3: field access then call ---
struct HasClosure {
    transform: i32 -> i32
}

// CHECK-DAG: fn test_field_call(v0 (s): HasClosure, v1 (x): i32) -> i32 {
// CHECK-NEXT-DAG:     closure_call(v0.0 : (i32) -> i32, v1) : i32
// CHECK-NEXT-DAG: }
fn test_field_call(s : HasClosure, x : i32) -> i32 {
    s.transform(x)
}
